{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx"
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "examples",
    "**/node_modules/**"
  ],
  "references": [
    { "path": "packages/core/types" },
    { "path": "packages/core/interfaces" },
    { "path": "packages/core/protocol" },
    { "path": "packages/core/utils" },
    { "path": "packages/free/app" },
    { "path": "packages/free/cli" },
    { "path": "packages/free/server" }
  ]
}
