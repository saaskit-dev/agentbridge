{
  "name": "@saaskit-dev/agentbridge",
  "version": "0.0.1",
  "description": "AgentBridge SDK core package - types, interfaces, and implementations",
  "author": "saaskit-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saaskit-dev/agentbridge.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./types": {
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types/index.cjs"
      },
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/types/index.mjs"
      }
    },
    "./interfaces": {
      "require": {
        "types": "./dist/interfaces/index.d.cts",
        "default": "./dist/interfaces/index.cjs"
      },
      "import": {
        "types": "./dist/interfaces/index.d.mts",
        "default": "./dist/interfaces/index.mjs"
      }
    },
    "./common": {
      "require": {
        "types": "./dist/common.d.cts",
        "default": "./dist/common.cjs"
      },
      "import": {
        "types": "./dist/common.d.mts",
        "default": "./dist/common.mjs"
      }
    },
    "./telemetry": {
      "require": {
        "types": "./dist/telemetry/index.d.cts",
        "default": "./dist/telemetry/index.cjs"
      },
      "import": {
        "types": "./dist/telemetry/index.d.mts",
        "default": "./dist/telemetry/index.mjs"
      }
    },
    "./encryption": {
      "require": {
        "types": "./dist/encryption/index.d.cts",
        "default": "./dist/encryption/index.cjs"
      },
      "import": {
        "types": "./dist/encryption/index.d.mts",
        "default": "./dist/encryption/index.mjs"
      }
    },
    "./telemetry/node": {
      "require": {
        "types": "./dist/telemetry/node.d.cts",
        "default": "./dist/telemetry/node.cjs"
      },
      "import": {
        "types": "./dist/telemetry/node.d.mts",
        "default": "./dist/telemetry/node.mjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc --noEmit && pkgroll",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "rotating-file-stream": "^3.2.9",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@types/node": "^25.3.2",
    "axios": "^1.13.5",
    "pkgroll": "^2.14.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@agentclientprotocol/sdk": ">=0.1.0",
    "axios": ">=1.0.0",
    "socket.io": ">=4.0.0",
    "socket.io-client": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@agentclientprotocol/sdk": {
      "optional": true
    },
    "axios": {
      "optional": true
    },
    "socket.io": {
      "optional": true
    },
    "socket.io-client": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
