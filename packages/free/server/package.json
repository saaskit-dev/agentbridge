{
  "name": "@free/server",
  "version": "0.0.1",
  "description": "Free Standalone Server - Complete reference server implementation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean",
    "build:bundle": "esbuild src/standalone.ts --outfile=dist/bundle.cjs --format=cjs --bundle --platform=node --target=node22 --external:@prisma/client --external:@prisma/engines --external:pg-native --external:cpu-features --external:@node-rs/* --external:sharp --external:privacy-kit --banner:js=\"const import_meta_shim = { url: require('url').pathToFileURL(__filename).toString() };\" --define:import.meta=import_meta_shim",
    "dev": "tsx --env-file=.env ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "standalone": "tsx ./src/standalone.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "docker:build": "cd ../.. && docker build -f packages/free/server/Dockerfile -t free-server:latest packages/free/server",
    "docker:run": "docker run -p 3000:3000 -v free-data:/app/data free-server:latest",
    "docker:compose": "docker-compose up --build",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "@agentbridge/interfaces": "workspace:*",
    "@agentbridge/protocol": "workspace:*",
    "@agentbridge/types": "workspace:*",
    "@agentbridge/utils": "workspace:*",
    "@date-fns/tz": "^1.2.0",
    "@electric-sql/pglite": "^0.3.15",
    "@fastify/bearer-auth": "^10.1.1",
    "@fastify/cors": "^10.0.1",
    "@octokit/webhooks": "^13.7.3",
    "@prisma/client": "^6.19.2",
    "@socket.io/postgres-adapter": "^0.5.0",
    "axios": "^1.6.8",
    "chalk": "4.1.2",
    "date-fns": "^4.1.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "octokit": "^5.0.3",
    "pg": "^8.18.0",
    "pglite-prisma-adapter": "^0.6.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma-json-types-generator": "^3.5.1",
    "privacy-kit": "^0.0.25",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.7.2",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "socket.io-adapter": "^2.5.5",
    "tmp": "^0.2.3",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.3",
    "@types/pg": "^8.16.0",
    "@types/semver": "^7.7.0",
    "@types/tmp": "^0.2.6",
    "@types/uuid": "^9.0.8",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.19.2",
    "tsup": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "^3.2.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "agent",
    "server",
    "websocket",
    "realtime"
  ],
  "license": "MIT"
}
