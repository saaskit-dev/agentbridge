# =============================================================================
# Free Server 环境变量配置
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------

# 运行环境: development | production
NODE_ENV=development

# 服务器端口和主机
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------

# 方式一: 使用外部 PostgreSQL (生产环境推荐，支持多实例部署)
# 设置 DATABASE_URL 后，Socket.IO 会自动启用 PostgreSQL adapter 支持多实例
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# 方式二: 使用内置 PGlite (默认，适合开发/单机部署)
# 如果不设置 DATABASE_URL，会自动使用 PGlite
# 注意: PGlite 模式不支持多实例部署
DATA_DIR=./data
PGLITE_DIR=./data/pglite

# -----------------------------------------------------------------------------
# 安全配置 (必须设置)
# -----------------------------------------------------------------------------

# 主密钥 - 用于加密/解密敏感数据 (必须更改!)
FREE_MASTER_SECRET=your-super-secret-master-key-change-in-production

# JWT 密钥 - 用于 session token 签名 (必须更改!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -----------------------------------------------------------------------------
# GitHub OAuth 配置 (可选 - 用于 GitHub 集成)
# 在 https://github.com/settings/developers 创建 OAuth App
# -----------------------------------------------------------------------------

# OAuth App 凭据
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_REDIRECT_URL=http://localhost:3000/api/v1/connect/github/callback

# Webhook 密钥 (用于验证 GitHub webhook 请求)
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# GitHub App 配置 (如果使用 GitHub App 而非 OAuth App)
# GITHUB_APP_ID=your-app-id
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# S3 存储配置 (可选 - 用于文件上传)
# 不配置则使用本地文件系统存储
# -----------------------------------------------------------------------------

# S3 兼容存储 (支持 MinIO, AWS S3, Cloudflare R2 等)
# S3_HOST=s3.example.com
# S3_PORT=9000
# S3_USE_SSL=true
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=free-uploads
# S3_PUBLIC_URL=https://s3.example.com/free-uploads

# 服务器公网 URL (用于生成文件访问链接)
# PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 监控配置 (可选)
# -----------------------------------------------------------------------------

# Prometheus metrics 端点
# METRICS_ENABLED=true
# METRICS_PORT=9090

# -----------------------------------------------------------------------------
# 语音功能配置 (可选)
# -----------------------------------------------------------------------------

# ElevenLabs API Key (用于 TTS/语音功能)
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# -----------------------------------------------------------------------------
# App 配置
# -----------------------------------------------------------------------------

# 前端 App URL (OAuth 回调跳转)
APP_URL=http://localhost:8081

# App 更新链接 (可选，用于版本检查)
# IOS_UPDATE_URL=https://apps.apple.com/app/xxx
# ANDROID_UPDATE_URL=https://play.google.com/store/apps/details?id=xxx

# -----------------------------------------------------------------------------
# 推送通知配置 (可选)
# -----------------------------------------------------------------------------

# Expo 推送通知 token
# EXPO_ACCESS_TOKEN=your-expo-push-token

# -----------------------------------------------------------------------------
# Self-Hosted OTA (可选)
# -----------------------------------------------------------------------------

# App 通过 /updates 拉取 OTA manifest。
# OTA bundle / assets 放 GitHub Releases；server 只维护 manifest 和 release metadata。
# EXPO_UPDATES_GATEWAY_ENABLED=true
# EXPO_UPDATES_GATEWAY_MODE=self-hosted
# EXPO_UPDATES_GATEWAY_TIMEOUT_MS=10000
# EXPO_UPDATES_ADMIN_TOKEN=replace-with-a-long-random-token

# 仅在兼容旧代理模式时需要：
# EXPO_UPDATES_UPSTREAM_URL=https://your-upstream.example.com/updates

# -----------------------------------------------------------------------------
# 遥测配置 (可选)
# -----------------------------------------------------------------------------

# New Relic 日志导出
# NEW_RELIC_LICENSE_KEY=your-newrelic-license-key
# NEW_RELIC_REGION=us
