# =============================================================================
# Free CLI Environment Variables
# =============================================================================
# Copy this file to .env.dev-local-server (local dev) or .env.integration-test
# and customize as needed. Load via: tsx --env-file .env.xxx src/index.ts

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Data directory (auth keys, logs, settings)
# Default: ~/.free
FREE_HOME_DIR=~/.free-dev

# Server URL
# Default: https://free-server.saaskit.app
FREE_SERVER_URL=http://localhost:3000

# Webapp URL (for OAuth callbacks)
# FREE_WEBAPP_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------

# Enable debug output
DEBUG=1

# Suppress Node.js deprecation warnings
NODE_NO_WARNINGS=1

# Verbose log level for telemetry (debug | info)
# LOG_LEVEL=debug

# Variant tag — set to "dev" for visual dev-mode indicator
# FREE_VARIANT=dev

# -----------------------------------------------------------------------------
# Daemon
# -----------------------------------------------------------------------------

# HTTP timeout for daemon health checks (ms)
# FREE_DAEMON_HTTP_TIMEOUT=10000

# Heartbeat interval (ms)
# FREE_DAEMON_HEARTBEAT_INTERVAL=30000

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Enable experimental features
# FREE_EXPERIMENTAL=true

# Disable caffeinate (macOS sleep prevention)
# FREE_DISABLE_CAFFEINATE=true
