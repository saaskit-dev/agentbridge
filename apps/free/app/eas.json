{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "development"
      }
    },
    "beta": {
      "channel": "beta",
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "development"
      }
    },
    "production": {
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production"
      }
    },
    "production-android": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760917195"
      },
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
