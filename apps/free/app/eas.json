{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": "apps/free-app",
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "development-store": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "preview-store": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "_comment": "TODO: Configure your own Apple Developer credentials",
        "_comment_appleId": "Get from: https://appleid.apple.com - your Apple ID email",
        "_comment_ascAppId": "Get from: https://appstoreconnect.apple.com -> My Apps -> [Your App] -> App Information -> Apple ID",
        "_comment_appleTeamId": "Get from: https://developer.apple.com/account -> Membership -> Team ID",
        "appleId": "",
        "ascAppId": "",
        "appleTeamId": ""
      }
    }
  }
}
