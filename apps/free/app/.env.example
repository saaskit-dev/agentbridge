# 环境变量模板，复制为 .env（开发）或 .env.production（生产）并填入真实值

# RevenueCat keys
# 开发：从 RevenueCat Dashboard > Test configuration 获取 test_xxx key
# 生产：从 RevenueCat Dashboard > Free (Stripe) > Public API Key 获取
EXPO_PUBLIC_REVENUE_CAT_APPLE=appl_your_apple_key_here
EXPO_PUBLIC_REVENUE_CAT_GOOGLE=goog_your_google_key_here
EXPO_PUBLIC_REVENUE_CAT_STRIPE=test_or_strp_your_stripe_key_here

# PostHog 分析（可选）
# EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_key
