{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Free",
  "version": "2026.4.17023356",
  "identifier": "app.saaskit.freecode",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "pnpm run desktop:web:dev",
    "beforeBuildCommand": "pnpm run desktop:web:build"
  },
  "app": {
    "windows": [
      {
        "title": "Free",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
